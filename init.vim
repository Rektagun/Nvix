" Key bindings can be changed, see below
call wilder#setup({'modes': [':']})

call wilder#set_option({'highlighter': wilder#basic_highlighter()})

colorscheme "gruvbox"

lua << EOF
require("headlines").setup()
EOF

lua << END
require('toggleterm').setup{}
END
 
lua << END
require('gitsigns').setup{}
END

