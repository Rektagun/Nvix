require("nvim-autopairs").setup {}
EOF

lua << END
require('telescope').setup{
defaults = {
	file_ignore_patterns = {}, -- Disable default file ignore patterns
},
extensions = {
	fzf = {
		hidden = false, -- Show hidden files and folders
	}
	}
}
END

